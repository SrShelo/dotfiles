" [[ OPTIONS ]]
" # MISC
set adblocker=off
set vimcommand="ghostty -e nvim"
set followchars=custom:qwerasdfzxcv
set smartcase=true
set searchpointeralignment="center"
set searchscope="local"
set historyperpage=50
set commandhist=all
"set windowtitle="%title - %app"
" Spellchecker
set spell=true
set spelllang=["en","es","system"]


" TODO: read this:
" https://github.com/Jelmerro/Vieb/blob/master/FAQ.md#why-cant-i-open-multiple-browser-windows
" to allow multiple windows to be opened safely (I want it to have one for
" browsing, and another one to render markdown while editing it in nvim)

" TODO: Check https://github.com/Jelmerro/Vieb/blob/master/Erwic.md for erwic
" mode

" # MOUSE
" middle click on links will open new tabs but won't focus them.
set nomousenewtabswitch

" # SECURITY
set downloadmethod=ask
set redirecttohttp
set resourcesallowed=[".*"]
" ## Permissions
set permissioncamera=ask
set permissiondisplaycapture=ask
set permissionmediadevices=allow
set permissionmicrophone=ask
set permissionpersistentstorage=allow
set permissionclipboardread=ask
set permissionclipboardwrite=allow
" ## DATA
set clearhistoryinterval="1month"
set cache="clearonquit"
set clearcookiesonquit=false

set useragent=""
"set useragent=%default
"set useragent="%firefox/Electron"
" What is a user agent? read this short article:
" https://www.howtogeek.com/114937/htg-explains-whats-a-browser-user-agent/
" Changing user agent to firefox prevent this browser from being declined by websites (like google services
" https://support.google.com/accounts/answer/7675428).
" Check your current useragent running in console
" `console.log(navigator.userAgent)` or visit this site:
" https://whatmyuseragent.com/

" # GUI
set nativetheme=dark
colorscheme my-flipped

set guifontsize=14
set guinavbar=always
set guitabbar=always
" options: always,onmove,onscroll,never
set guiscrollbar=always
set guifullscreennavbar=oninput
set guifullscreentabbar=onupdate
set guihidetimeout=2500
" options: hidden,scroll,wrap
set taboverflow="wrap"
set devtoolsposition=vsplit

" options: none,spinner,line,all
set loadingindicator="line"
set notificationposition="bottomright"

set mapsuggestposition=bottomleft
set followlabelposition=insidebottomright
set timeout=true
set timeoutlen=30000

" TABS
set tabnewposition=right
set closablepinnedtabs=false

" [[ SEARCH WORDS ]]
set searchwords={ "d": "https://duckduckgo.com/?t=h_&q=%s&ia=web", "ddg": "https://duckduckgo.com/?t=h_&q=%s&ia=web", "g": "https://google.com/search?q=%s", "google": "https://google.com/search?q=%s" }

