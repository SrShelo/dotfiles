keybind = clear

keybind = ctrl+alt+delete=quit
keybind = ctrl+shift+delete=crash:main

# keybind = ctrl+l=clear_screen
# keybind = ctrl+shift+l=reset

keybind = ctrl+alt+comma=open_config
keybind = ctrl+f5=reload_config

# Navigation
keybind = ctrl+alt+page_up=scroll_page_fractional:-0.5
keybind = ctrl+alt+page_down=scroll_page_fractional:0.5
keybind = ctrl+alt+s=scroll_page_fractional:-0.1
keybind = ctrl+alt+z=scroll_page_fractional:0.1
keybind = ctrl+alt+j=scroll_page_fractional:0.1
keybind = ctrl+alt+k=scroll_page_fractional:-0.1

# Clipboard
# keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+shift+c=copy_to_clipboard
# keybind = ctrl+v=paste_from_clipboard
keybind = performable:ctrl+shift+v=paste_from_clipboard
# keybind = performable:ctrl+alt+v=paste_from_clipboard

# Appearance
keybind = ctrl+alt+minus=decrease_font_size:1
keybind = ctrl+alt+plus=increase_font_size:1
